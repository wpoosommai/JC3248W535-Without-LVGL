#include <Arduino.h>
#include <Arduino_GFX_Library.h>
#include <JC3248W535.h>
#include <Wire.h>

// -------------------------------------------------------------------------------------------------
// การตั้งค่าพื้นฐานของจอ
// -------------------------------------------------------------------------------------------------
#define GFX_BL               1
#define SCREEN_ROTATION      0
#define LCD_NATIVE_WIDTH     320
#define LCD_NATIVE_HEIGHT    480

// -------------------------------------------------------------------------------------------------
// สร้างบัส QSPI ของจอ JC3248W535
// หมายเหตุ: ใช้ชุดขาเดียวกับไฟล์เดิม dashboard_frame_viewer_LAN_V2
// -------------------------------------------------------------------------------------------------
Arduino_DataBus *bus = new Arduino_ESP32QSPI(
  45,   // CS
  47,   // SCK
  21,   // D0
  48,   // D1
  40,   // D2
  39    // D3
);

// -------------------------------------------------------------------------------------------------
// สร้างออบเจ็กต์จอจริง
// -------------------------------------------------------------------------------------------------
Arduino_GFX *gfx = new Arduino_AXS15231B(
  bus,
  GFX_NOT_DEFINED,
  0,
  false,
  LCD_NATIVE_WIDTH,
  LCD_NATIVE_HEIGHT
);

// -------------------------------------------------------------------------------------------------
// ฟังก์ชันเปิด backlight
// -------------------------------------------------------------------------------------------------
void setBacklight(uint8_t level)
{
  pinMode(GFX_BL, OUTPUT);
  digitalWrite(GFX_BL, (level > 0) ? HIGH : LOW);
}

// -------------------------------------------------------------------------------------------------
// setup()
// -------------------------------------------------------------------------------------------------
void setup()
{
  Serial.begin(115200);
  delay(200);

  // เปิด backlight
  setBacklight(255);

  // เริ่มต้นจอ
  if (!gfx->begin()) {
    Serial.println("gfx->begin() failed");
    while (1) {
      delay(1000);
    }
  }

  // ตั้งค่าการหมุนจอ
  Serial.println("SCREEN_ROTATION");
  gfx->setRotation(SCREEN_ROTATION);

  // ทดสอบสีเต็มจอ
  Serial.println("COLOR_RED");
  gfx->fillScreen(COLOR_RED);
  delay(1500);

  Serial.println("COLOR_GREEN");
  gfx->fillScreen(COLOR_GREEN);
  delay(1500);

  Serial.println("COLOR_BLUE");
  gfx->fillScreen(COLOR_BLUE);
  delay(1500);

  // ล้างจอเป็นสีดำ
  Serial.println("COLOR_BLACK");
  gfx->fillScreen(COLOR_BLACK);
  delay(1500);

  // วาดกรอบสี่เหลี่ยม
  Serial.println("drawRect(40, 150, 240, 100, COLOR_YELLOW)");
  gfx->drawRect(40, 150, 240, 100, COLOR_YELLOW);
  gfx->drawRect(41, 151, 238, 98, COLOR_YELLOW);
  delay(1500);
  
  // ตั้งค่าข้อความ
  gfx->setTextSize(3);
  gfx->setTextColor(COLOR_WHITE, COLOR_BLACK);
  gfx->setCursor(70, 180);
  gfx->println("Hello");
  gfx->setCursor(70, 220);
  gfx->println("World");

  Serial.println("Hello World display complete.");
}

// -------------------------------------------------------------------------------------------------
// loop()
// -------------------------------------------------------------------------------------------------
void loop()
{
  delay(1000);
}
